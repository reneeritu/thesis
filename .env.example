PORT=3000
# Frontend dev proxy targets http://127.0.0.1:$PORT (reads this file from repo root). Override if needed:
# VITE_API_PROXY_TARGET=http://127.0.0.1:3001
MONGODB_URI=mongodb://localhost:27017/aura2
JWT_SECRET=replace-with-a-strong-random-secret
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=replace-with-64-hex-chars-for-aes256
NODE_ENV=development
# Optional local UI dev: copy this file to `.env` in the same folder (repo root), then set:
# DEV_MANDALA_DEMO_SCORES=true
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# === Simulation mode (dev/demo only) ===
# Enable the /sim/* routes and the SIM launcher button in the header.
# SIM_MODE=on
# Comma-separated aliases who may start/pause/reset simulations. Empty = any
# authenticated user (recommended only on local dev).
# SIM_ADMIN_ALIASES=
# Frontend mirror — set in frontend/.env to show the SIM button.
# VITE_SIM_MODE=on

